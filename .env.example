# Local development database only.
# Do not put production, Supabase pooler, or Vercel database URLs here.

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/metrix_ai_os_dev"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/metrix_ai_os_dev"

# Optional: only use a local shadow database for Prisma migration development.
# SHADOW_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/metrix_ai_os_shadow"

# ─── Daily Briefing Scheduler ─────────────────────────────────────────────────
# Protects POST /api/briefing/generate from unauthorized access.
# Must match the BRIEFING_CRON_SECRET set in GitHub Actions secrets.
# Generate with: openssl rand -hex 32
# Leave unset in local development — the endpoint allows unauthenticated calls
# when NODE_ENV !== "production" and no secret is configured.
BRIEFING_CRON_SECRET=

# ─── Email OTP (Resend) ────────────────────────────────────────────────────────
# Required in production. Get your key at https://resend.com
# Leave unset in local development — OTP code will appear in console instead.
RESEND_API_KEY=
# Optional: sender address shown to users. Must be a verified domain in Resend.
# EMAIL_FROM="Metrix <noreply@metrixai.app>"
